<Window x:Class="Wasabi.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Wasabi.App.Controls"
        Title="WASABI — Audio Router"
        Width="1280" Height="820"
        MinWidth="960" MinHeight="640">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}" Padding="12,10" BorderBrush="#333945" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="WASABI" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Accent}" Margin="0,0,16,0"/>
                    <TextBlock Text="Windows Audio Schema Block Interface" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="+ App" Click="AddAppSource_Click" Margin="4,0"/>
                    <Button Content="+ Dispositivo (loopback)" Click="AddDeviceLoopback_Click" Margin="4,0"/>
                    <Button Content="+ Mixer" Click="AddMixer_Click" Margin="4,0"/>
                    <Button Content="+ Splitter" Click="AddSplitter_Click" Margin="4,0"/>
                    <Button Content="+ Bus virtuale" Click="AddVirtualBus_Click" Margin="4,0"/>
                    <Button Content="+ Uscita" Click="AddOutput_Click" Margin="4,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Apri patch…" Click="OpenPatch_Click" Margin="4,0"/>
                    <Button Content="Salva patch…" Click="SavePatch_Click" Margin="4,0"/>
                    <Button Content="Calibra latenza…" Click="CalibrateLatency_Click" Margin="4,0"/>
                    <Button x:Name="StartButton" Content="▶ Avvia routing" Style="{StaticResource AccentButton}" Click="StartRouting_Click" Margin="8,0,4,0"/>
                    <Button x:Name="StopButton" Content="■ Stop" Click="StopRouting_Click" IsEnabled="False" Margin="4,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Canvas editor -->
        <local:BlockCanvas x:Name="Editor" Grid.Row="1" Margin="8"/>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource BgPanel}" Padding="12,8" BorderBrush="#333945" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock x:Name="StatusText" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                <TextBlock HorizontalAlignment="Right" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"
                           Text="Trascina i blocchi · clic su porta OUT poi IN per collegare · doppio clic per configurare"/>
            </Grid>
        </Border>
    </Grid>
</Window>
