<UserControl x:Class="Wasabi.App.Controls.BlockNodeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="180">
    <Border Background="{StaticResource BgNode}" BorderBrush="#3A4150" BorderThickness="1" CornerRadius="10" Padding="10">
        <StackPanel>
            <Grid Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="TypeBadge" FontSize="10" Foreground="{StaticResource Accent}" FontWeight="Bold" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TitleText" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="130"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="⚙" Width="24" Height="24" Padding="0" Click="Configure_Click" ToolTip="Configura"/>
                    <Button Content="✕" Width="24" Height="24" Padding="0" Margin="4,0,0,0" Click="Delete_Click" ToolTip="Elimina"/>
                </StackPanel>
            </Grid>

            <TextBlock x:Name="SubtitleText" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/>

            <ItemsControl x:Name="PortList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" HorizontalAlignment="Left"
                                    Content="{Binding Label}"
                                    Tag="{Binding Id}"
                                    Click="Port_Click"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource TextPrimary}" Padding="0"/>
                            <Ellipse Grid.Column="1" Width="12" Height="12" Tag="{Binding Id}" MouseLeftButtonDown="PortEllipse_Click">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource PortOutput}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Direction}" Value="Input">
                                                <Setter Property="Fill" Value="{StaticResource PortInput}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
