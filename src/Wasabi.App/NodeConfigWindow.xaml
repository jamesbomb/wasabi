<Window x:Class="Wasabi.App.NodeConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configura blocco"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        MinWidth="420">
    <Border Background="{StaticResource BgPanel}" Padding="20">
        <StackPanel>
            <TextBlock Text="Nome" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
            <TextBox x:Name="TitleBox" Margin="0,0,0,12"/>

            <StackPanel x:Name="AppPanel" Visibility="Collapsed" Margin="0,0,0,12">
                <TextBlock Text="Applicazione" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                <ComboBox x:Name="ProcessCombo" DisplayMemberPath="DisplayName" MinWidth="360"/>
            </StackPanel>

            <StackPanel x:Name="DevicePanel" Visibility="Collapsed" Margin="0,0,0,12">
                <TextBlock Text="Dispositivo audio" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                <ComboBox x:Name="DeviceCombo" DisplayMemberPath="Name" MinWidth="360"/>
            </StackPanel>

            <StackPanel x:Name="MixerPanel" Visibility="Collapsed" Margin="0,0,0,12">
                <TextBlock Text="Numero ingressi" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                <Slider x:Name="InputCountSlider" Minimum="2" Maximum="8" IsSnapToTickEnabled="True" TickFrequency="1"/>
            </StackPanel>

            <StackPanel x:Name="SplitterPanel" Visibility="Collapsed" Margin="0,0,0,12">
                <TextBlock Text="Numero uscite" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                <Slider x:Name="OutputCountSlider" Minimum="2" Maximum="8" IsSnapToTickEnabled="True" TickFrequency="1"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="Volume" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Width="80"/>
                <Slider x:Name="VolumeSlider" Minimum="0" Maximum="2" Width="220" TickFrequency="0.1"/>
                <TextBlock x:Name="VolumeLabel" Margin="8,0,0,0" VerticalAlignment="Center" Width="40"/>
            </StackPanel>

            <CheckBox x:Name="MuteCheck" Content="Muto" Margin="0,0,0,16"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Annulla" IsCancel="True" Margin="0,0,8,0"/>
                <Button Content="OK" IsDefault="True" Style="{StaticResource AccentButton}" Click="Ok_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
